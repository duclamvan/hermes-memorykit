# Hermes MemoryKit public template
# Copy relevant values into ~/.hermes/.env or your deployment secret store.

LCM_LARGE_OUTPUT_EXTERNALIZATION_ENABLED=true
LCM_LARGE_OUTPUT_EXTERNALIZATION_THRESHOLD_CHARS=12000
LCM_LARGE_OUTPUT_TRANSCRIPT_GC_ENABLED=false
LCM_CONTEXT_THRESHOLD=0.70

# Optional paths used by these public scripts
MEMORY_STACK_DOCS_PATH=~/notes
MEMORY_STACK_GRAPH_PATH=./data/entity-graph.json
MEMORY_STACK_LCM_DB=~/.hermes/lcm.db
MEMORY_STACK_REPORT_DIR=./reports
